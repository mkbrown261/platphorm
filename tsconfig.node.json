{
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ESNext",
    "strict": true,
    "skipLibCheck": true,
    "types": ["electron-vite/node", "node"],
    "paths": {
      "@main/*": ["./electron/main/*"]
    }
  },
  "include": [
    "electron.vite.config.*",
    "electron/**/*"
  ]
}
